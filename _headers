# Netlify headers for PuzzleHub (production)
# https://puzzle-hub.netlify.app/

# ---- Global security headers ----
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://pagead2.googlesyndication.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; manifest-src 'self'; connect-src 'self' https://pagead2.googlesyndication.com; frame-src 'self' https://pagead2.googlesyndication.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests

# ---- Static assets: long cache, immutable (1 year) ----
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=31536000, immutable

# Minified, content-hashed-equivalent bundles at the root
/script.min.js
  Cache-Control: public, max-age=31536000, immutable

/style.min.css
  Cache-Control: public, max-age=31536000, immutable

# ---- HTML: short, revalidating cache so updates roll out fast ----
/index.html
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/google159ef9242b8ed752.html
  Cache-Control: public, max-age=86400

# ---- Service worker: always fresh so updates are picked up ----
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# ---- SEO / ads files: daily refresh ----
/robots.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400

/ads.txt
  Cache-Control: public, max-age=86400

/llms.txt
  Cache-Control: public, max-age=86400

# ---- Manifest: weekly ----
/manifest.json
  Cache-Control: public, max-age=604800
